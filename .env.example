APP_NAME=CharityHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=charityhub
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Process background jobs (like emails) using the database
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail Configuration (e.g., Mailtrap) ─────────────────────────────────────────
# Get these credentials from your SMTP provider (e.g., Mailtrap.io)
MAIL_MAILER=smtp
MAIL_SCHEME=null
# The hostname of your SMTP server
MAIL_HOST=live.smtp.mailtrap.io
# The port of your SMTP server
MAIL_PORT=587
# Your SMTP username
MAIL_USERNAME=your_smtp_username_here
# Your SMTP password
MAIL_PASSWORD=your_smtp_password_here
# The default email address the app sends emails from
MAIL_FROM_ADDRESS="hello@example.com"
# The default name the app sends emails from
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Stripe Configuration ────────────────────────────────────────────────────────
# Get your publishable key (pk_test_...) from the Stripe Dashboard > Developers > API keys
STRIPE_KEY=pk_test_your_stripe_publishable_key_here
# Get your secret key (sk_test_...) from the Stripe Dashboard > Developers > API keys
STRIPE_SECRET=sk_test_your_stripe_secret_key_here
# Get your webhook secret (whsec_...) by creating a webhook endpoint in Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ── Google OAuth Configuration ──────────────────────────────────────────────────
# Create an OAuth Client ID in Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
# The secret key generated for your Google OAuth app
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
# The authorized redirect URI for your app (must match Google Console setting)
GOOGLE_REDIRECT_URI=http://localhost/auth/google/callback

# ── Google Maps Configuration ───────────────────────────────────────────────────
# Generate an API key with Maps JavaScript API enabled in Google Cloud Console
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
